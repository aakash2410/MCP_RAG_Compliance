# ── LLM-as-Judge (plug and play) ─────────────────────────────────────────────
# JUDGE_PROVIDER: anthropic (default) | openai
# JUDGE_MODEL:    model name — defaults to claude-sonnet-4-6 (anthropic) or gpt-4o (openai)
# JUDGE_API_KEY:  overrides ANTHROPIC_API_KEY / OPENAI_API_KEY if set
# JUDGE_BASE_URL: any OpenAI-compatible endpoint (Ollama, Groq, Together, vLLM, etc.)
#
# Examples:
#   Anthropic (default):  ANTHROPIC_API_KEY=sk-ant-...
#   OpenAI:               JUDGE_PROVIDER=openai  OPENAI_API_KEY=sk-...
#   Ollama (local):       JUDGE_PROVIDER=openai  JUDGE_BASE_URL=http://localhost:11434/v1  JUDGE_MODEL=llama3.1
#   Groq:                 JUDGE_PROVIDER=openai  JUDGE_BASE_URL=https://api.groq.com/openai/v1  JUDGE_MODEL=llama-3.1-70b-versatile  JUDGE_API_KEY=gsk_...
#   Together AI:          JUDGE_PROVIDER=openai  JUDGE_BASE_URL=https://api.together.xyz/v1  JUDGE_MODEL=meta-llama/Llama-3-70b-chat-hf  JUDGE_API_KEY=...

ANTHROPIC_API_KEY=your_key_here
# JUDGE_PROVIDER=anthropic
# JUDGE_MODEL=claude-sonnet-4-6
# JUDGE_API_KEY=
# JUDGE_BASE_URL=

# ── Auditor settings ──────────────────────────────────────────────────────────
RAG_AUDITOR_PRIVATE_KEY_PATH=./keys/private_key.pem
RAG_AUDITOR_PUBLIC_KEY_PATH=./keys/public_key.pem
RAG_AUDITOR_STORE_DIR=./.rag_audits
RAG_AUDITOR_CERT_TTL_HOURS=168
